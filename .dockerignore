# Git
.git/
.gitignore
.gitattributes

# Python artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
.venv*/

# Secrets (never in images)
.env
.env.*
*.key
*.pem
secrets/
vault.json
audit.jsonl
.scanned

# Local state (not needed in containers)
