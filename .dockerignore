*.sqlite
*.db
.DS_Store

# Docs (not needed at runtime)
docs/
*.md
*.mdx

# Tests (not needed at runtime)
tests/
test_*
*_test.py

# CI
.github/
.gitlab-ci.yml

# IDE
.idea/
.vscode/
